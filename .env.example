DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_pipeline_runner"
REDIS_URL="redis://localhost:6379"
OPENAI_API_KEY="your-openai-key"
ANTHROPIC_API_KEY="your-anthropic-key"
OPENROUTER_API_KEY="your-openrouter-key"

# Audio & Voice Transcription
WHISPER_API_KEY="your-whisper-key" # Defaults to OPENAI_API_KEY if omitted
ELEVENLABS_API_KEY="your-elevenlabs-key"

# External LLMs & Extensible Agents
GEMINI_API_KEY="your-gemini-key"
PERPLEXITY_API_KEY="your-perplexity-key"
BANANA_API_KEY="your-banana-key"
FLOW_API_KEY="your-flow-key"
RUNWAY_API_KEY="your-runway-key"
FATHOM_API_KEY="your-fathom-key"
GAMMA_API_KEY="your-gamma-key"
CURSOR_API_KEY="your-cursor-key"

# Cloudflare R2 Storage (Artifact & File Persistence)
R2_ACCOUNT_ID="your-r2-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET="your-r2-bucket"
R2_PUBLIC_URL="https://your-public-r2-bucket.com"

PORT=3000