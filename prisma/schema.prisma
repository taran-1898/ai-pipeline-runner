generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pipeline {
  id          String         @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime       @default(now())

  steps PipelineStep[]
  runs  Run[]
}

model PipelineStep {
  id            String   @id @default(cuid())
  pipeline      Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  pipelineId    String
  stepOrder     Int
  stepType      String
  promptTemplate String
  schema        Json?
  dependsOn     String[] @default([])
  dependsOnStepId String?

  runSteps RunStep[]

  @@unique([pipelineId, stepOrder])
}

model Run {
  id         String    @id @default(cuid())
  pipeline   Pipeline  @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  pipelineId String
  input      Json
  status     RunStatus @default(PENDING)
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  steps RunStep[]
  artifacts RunArtifact[]
}

model RunStep {
  id         String   @id @default(cuid())
  run        Run      @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId      String
  step       PipelineStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  stepId     String
  modelUsed  String
  prompt     String
  response   String
  tokenCost  Int?
  durationMs Int
  reviewStatus  String?
  reviewComments String?
  validationErrors String?
  status     String
  startTime  DateTime
  endTime    DateTime
}

model RunArtifact {
  id        String   @id @default(cuid())
  run       Run      @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId     String
  type      String
  fileKey   String
  fileUrl   String
  metadata  Json?
  createdAt DateTime @default(now())
}

enum RunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model ModelMetrics {
  model        String  @id
  successCount Int     @default(0)
  failureCount Int     @default(0)
  avgLatency   Float   @default(0) // milliseconds
  avgCost      Float?
}

model ConversationSession {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  lastActiveAt DateTime @default(now())
  contextJson Json?

  messages ConversationMessage[]
}

model ConversationMessage {
  id        String   @id @default(cuid())
  session   ConversationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String
  role      String
  content   String
  createdAt DateTime @default(now())
}

model ExternalFile {
  id        String   @id @default(cuid())
  provider  String
  fileId    String
  filename  String
  mimeType  String
  createdAt DateTime @default(now())
}

