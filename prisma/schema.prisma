generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pipeline {
  id          String         @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime       @default(now())

  steps PipelineStep[]
  runs  Run[]
}

model PipelineStep {
  id            String   @id @default(cuid())
  pipeline      Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  pipelineId    String
  stepOrder     Int
  stepType      String
  promptTemplate String
  schema        Json?
  dependsOn     String[] @default([])

  runSteps RunStep[]

  @@unique([pipelineId, stepOrder])
}

model Run {
  id         String    @id @default(cuid())
  pipeline   Pipeline  @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  pipelineId String
  input      Json
  status     RunStatus @default(PENDING)
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  steps RunStep[]
}

model RunStep {
  id         String   @id @default(cuid())
  run        Run      @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId      String
  step       PipelineStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  stepId     String
  modelUsed  String
  prompt     String
  response   String
  tokenCost  Int?
  durationMs Int
  reviewStatus  String?
  reviewComments String?
  validationErrors String?
  status     String
  startTime  DateTime
  endTime    DateTime
}

enum RunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

